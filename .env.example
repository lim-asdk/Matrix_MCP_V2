# Matrix MCP v2.0 — Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# 🔑 API KEYS
# OpenAI / xAI / Anthropic / DeepSeek (OpenAI-compatible)
OPENAI_API_KEY=your_api_key_here

# 🌐 ENDPOINTS (OPTIONAL)
# Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# ⚙️ SERVER SETTINGS
# Port for the web interface (default: 2027)
PORT=2027
